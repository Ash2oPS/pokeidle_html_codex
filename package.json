{
  "name": "pokeidle-html-codex",
  "private": true,
  "version": "0.1.15",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "build:vendors": "node scripts/build-browser-vendors.mjs",
    "tool:custom-skins": "node scripts/custom-skin-tool-server.mjs",
    "desktop:start": "electron .",
    "desktop:build": "set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win nsis --x64",
    "test:save": "node --test tests/*.mjs",
    "zone:csv:export": "node scripts_export_zone_encounters_csv.mjs",
    "zone:editor:build": "node scripts/generate_zone_encounters_workbook.mjs",
    "zone:editor:export": "node scripts/export_zone_encounters_from_workbook.mjs"
  },
  "dependencies": {
    "@tweenjs/tween.js": "^25.0.0",
    "howler": "^2.2.4",
    "papaparse": "^5.5.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "electron": "^35.7.2",
    "electron-builder": "^26.0.12",
    "exceljs": "^4.4.0",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2"
  },
  "build": {
    "appId": "com.ash2ops.pokeidle",
    "productName": "PokeIdle",
    "directories": {
      "output": "output/electron-dist"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
